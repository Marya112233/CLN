<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050711"
    android:padding="22dp">

    <TextView
        android:id="@+id/resourcesTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📚 Resources"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginTop="40dp"/>

    <EditText
        android:id="@+id/resourceNameInput"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_below="@id/resourcesTitle"
        android:layout_marginTop="20dp"
        android:hint="Resource Name"
        android:textColor="#FFFFFF"
        android:textColorHint="#AAAAAA"
        android:backgroundTint="#B13DFF"/>

    <EditText
        android:id="@+id/resourceLinkInput"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_below="@id/resourceNameInput"
        android:layout_marginTop="12dp"
        android:hint="Resource Link"
        android:textColor="#FFFFFF"
        android:textColorHint="#AAAAAA"
        android:backgroundTint="#B13DFF"/>

    <ListView
        android:id="@+id/resourcesList"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/resourceLinkInput"
        android:layout_above="@id/bottomButtons"
        android:layout_marginTop="20dp"
        android:divider="@android:color/transparent"
        android:dividerHeight="10dp"/>

    <LinearLayout
        android:id="@+id/bottomButtons"
        android:layout_width="match_parent"
        android:layout_height="140dp"
        android:layout_alignParentBottom="true"
        android:orientation="vertical">

        <Button
            android:id="@+id/addResourceBtn"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="ADD RESOURCE"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#B13DFF"/>

        <Button
            android:id="@+id/backHomeBtn"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="12dp"
            android:text="BACK TO HOME"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1A1F3A"/>

    </LinearLayout>

</RelativeLayout>